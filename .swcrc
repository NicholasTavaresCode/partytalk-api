{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": false,
            "decorators": true,
            "decoratorsBeforeExport": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "keepClassNames": true,
        "target": "es2023",
        "baseUrl": "./",
        "paths": {
            "src/*": ["src/*"]
        }
    },
    "module": {
        "type": "commonjs"
    }
}