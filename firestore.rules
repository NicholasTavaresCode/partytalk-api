rules_version = '2';

// These rules apply to the LOCAL EMULATOR only. The API talks to Firestore with
// admin credentials (which bypass rules), so this open policy just keeps the
// emulator from rejecting direct access during development. Do NOT ship these
// rules to a real project.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
