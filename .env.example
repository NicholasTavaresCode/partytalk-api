# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# Comma-separated list of allowed CORS origins (frontend URLs). Use * only in dev.
CORS_ORIGINS=http://localhost:5173

# ─── Google Cloud / Firebase ────────────────────────────────────────────────
# GCP project that owns Firestore + Firebase Auth + Vertex AI.
GCP_PROJECT_ID=partytalk-dev

# Path to a service-account JSON key. Leave empty to use Application Default
# Credentials (ADC) — e.g. `gcloud auth application-default login` locally, or
# the attached service account when running on Cloud Run / GKE.
GOOGLE_APPLICATION_CREDENTIALS=

# Point at the local Firestore emulator during tests/dev. Leave empty for real Firestore.
# Example: 127.0.0.1:8080
FIRESTORE_EMULATOR_HOST=

# ─── Authentication (Google Identity / "Sign in with Google") ────────────────
# OAuth 2.0 Web client id. The frontend signs in with this client; the API
# verifies every ID token against it as the expected audience.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional comma-separated Google Workspace domain allow-list. Leave empty for
# open sign-up (any verified Google account). Example: example.com,partner.com
ALLOWED_AUTH_DOMAINS=
# TEMP local-testing escape hatch. When true, the API skips Google token
# verification and treats every request as a fixed dev user. MUST be false in
# any shared or deployed environment.
AUTH_DISABLED=false

# ─── Vertex AI (Gemini) ─────────────────────────────────────────────────────
VERTEX_LOCATION=us-central1
# Conversational AI host model
VERTEX_HOST_MODEL=gemini-2.0-flash
# Rubric-based IELTS scoring model (favor a stronger model for grading)
VERTEX_SCORING_MODEL=gemini-2.0-flash

# ─── Room AI facilitator ────────────────────────────────────────────────────
# The AI listens to the live transcript and auto-suggests a new, related topic
# after this many transcript segments...
ROOM_SUGGEST_EVERY_SEGMENTS=8
# ...or after this many milliseconds of silence in a live room.
ROOM_SILENCE_MS=25000
# How many recent transcript segments to feed the model as context.
ROOM_CONTEXT_SEGMENTS=25
